{
  "id": "choiceJump",
  "title": "Choice-condition logic jump test",
  "theme": {
    "href": "https://api.typeform.com/themes/6lPNE6"
  },
  "workspace": {
    "href": "https://api.typeform.com/workspaces/WA44hg"
  },
  "settings": {
    "is_public": true,
    "is_trial": false,
    "language": "en",
    "progress_bar": "percentage",
    "show_progress_bar": true,
    "show_typeform_branding": true,
    "meta": {
      "allow_indexing": false
    }
  },
  "thankyou_screens": [
    {
      "ref": "default_tys",
      "title": "Done! Your information was sent perfectly.",
      "properties": {
        "show_button": false,
        "share_icons": false
      }
    }
  ],
  "fields": [
    {
      "id": "cjColorField",
      "title": "What is your favorite color?",
      "ref": "color",
      "properties": {
        "randomize": false,
        "allow_multiple_selection": false,
        "allow_other_choice": false,
        "vertical_alignment": true,
        "choices": [
          {
            "id": "cjChoiceRed",
            "ref": "red",
            "label": "Red"
          },
          {
            "id": "cjChoiceBlue",
            "ref": "blue",
            "label": "Blue"
          }
        ]
      },
      "validations": {
        "required": false
      },
      "type": "multiple_choice"
    },
    {
      "id": "cjRedTarget",
      "title": "You picked Red!",
      "ref": "redTarget",
      "properties": {
        "hide_marks": false,
        "button_text": "Continue"
      },
      "type": "statement"
    },
    {
      "id": "cjBlueTarget",
      "title": "You picked Blue!",
      "ref": "blueTarget",
      "properties": {
        "hide_marks": false,
        "button_text": "Continue"
      },
      "type": "statement"
    },
    {
      "id": "cjThanks",
      "title": "Thanks for playing!",
      "ref": "thanksStatement",
      "properties": {
        "hide_marks": false,
        "button_text": "Continue"
      },
      "type": "statement"
    },
    {
      "ref": "default_tys",
      "title": "Done! Your information was sent perfectly.",
      "properties": {
        "show_button": false,
        "share_icons": false
      },
      "type": "thankyou_screen"
    }
  ],
  "logic": [
    {
      "type": "field",
      "ref": "color",
      "actions": [
        {
          "action": "jump",
          "details": {
            "to": {
              "type": "field",
              "value": "redTarget"
            }
          },
          "condition": {
            "op": "is",
            "vars": [
              {
                "type": "field",
                "value": "color"
              },
              {
                "type": "choice",
                "value": "red"
              }
            ]
          }
        },
        {
          "action": "jump",
          "details": {
            "to": {
              "type": "field",
              "value": "blueTarget"
            }
          },
          "condition": {
            "op": "is",
            "vars": [
              {
                "type": "field",
                "value": "color"
              },
              {
                "type": "choice",
                "value": "blue"
              }
            ]
          }
        }
      ]
    },
    {
      "type": "field",
      "ref": "redTarget",
      "actions": [
        {
          "action": "jump",
          "details": {
            "to": {
              "type": "field",
              "value": "thanksStatement"
            }
          },
          "condition": {
            "op": "always",
            "vars": []
          }
        }
      ]
    }
  ],
  "_links": {
    "display": "https://nandanrao.typeform.com/to/choiceJump"
  },
  "custom_messages": {}
}
