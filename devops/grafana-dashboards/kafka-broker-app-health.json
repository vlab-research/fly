      "title": "Under-Replicated Partitions",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Free space percentage on Kafka broker PVCs. Low values trigger alerts.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "pluginVersion": "7.4.2",
      "targets": [
        {
          "expr": "100 * (kubelet_volume_stats_available_bytes{persistentvolumeclaim=~\"data-kafka-kafka-.*\"} / kubelet_volume_stats_capacity_bytes{persistentvolumeclaim=~\"data-kafka-kafka-.*\"})",
          "interval": "",
          "legendFormat": "{{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "Kafka PVC Free Space (%)",
      "type": "gauge"
    },
