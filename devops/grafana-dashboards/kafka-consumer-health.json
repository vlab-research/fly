      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Kafka consumer alerts currently firing (KafkaConsumerStuck, KafkaConsumerDrainSLOBreach, KafkaConsumerGroupAbsent).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "alertstate"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "firing": {
                        "color": "red",
                        "index": 0
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 6,
      "options": {
        "showHeader": true
      },
      "pluginVersion": "7.4.2",
      "targets": [
        {
          "expr": "ALERTS{alertname=~\"KafkaConsumer.*\",alertstate=\"firing\"}",
          "format": "table",
          "instant": true,
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Firing Consumer Alerts",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "prometheus": true,
              "prometheus_replica": true
            },
            "indexByName": {
              "alertname": 0,
              "env": 1,
              "consumergroup": 2,
              "topic": 3,
              "severity": 4,
              "alertstate": 5
            },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    }
  ],
