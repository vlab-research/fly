# DinersClub Environment Configuration
# This file is meant to be used with tools that support env file loading

# Database Configuration
CHATBASE_DATABASE=chatroach
CHATBASE_HOST=localhost
CHATBASE_PORT=26257
CHATBASE_USER=root
CHATBASE_MAX_CONNECTIONS=10

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=vlab-payment
KAFKA_GROUP=dinersclub
KAFKA_POLL_TIMEOUT=1s
DINERSCLUB_BATCH_SIZE=100

# Processing Configuration
DINERSCLUB_PROVIDERS=fake,reloadly,giftcard,http,dingconnect
DINERSCLUB_POOL_SIZE=10
DINERSCLUB_RETRY_PROVIDER=2m
DINERSCLUB_RETRY_BOTSERVER=2m
BACK_OFF_RANDOM_FACTOR=0.5

# Cache Configuration
CACHE_TTL=1h
CACHE_NUM_COUNTERS=10000
CACHE_MAX_COST=10000
CACHE_BUFFER_ITEMS=64

# Provider Configuration
RELOADLY_SANDBOX=true

# BotServer Configuration
BOTSERVER_URL=http://localhost:8080/synthetic

# IMPORTANT: Sensitive credentials are loaded from .env-ding
# This file should NOT be committed to version control.
# Include .env-ding in docker run or docker-compose commands:
# docker run --env-file .env --env-file .env-ding dinersclub:latest
# or in docker-compose:
# env_file:
#   - .env
#   - .env-ding
